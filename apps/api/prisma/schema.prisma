// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(uuid())
  phone        String       @unique
  isPro        Boolean      @default(false)
  isBusiness   Boolean      @default(false)
  links        Link[]
  ownedTeam    Team?        @relation("TeamOwner")
  teamMembers  TeamMember[]
  apiKeys      ApiKey[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Link {
  id           String    @id @default(uuid())
  originalUrl  String
  slug         String    @unique
  clicks       Int       @default(0)

  // Metadata for the Dashboard
  title        String?
  description  String?
  favicon      String?

  // Pro Features
  customSlug   Boolean   @default(false)
  password     String?   // Hashed password
  expiresAt    DateTime?
  isActive     Boolean   @default(true)

  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  analytics    Analytics[]
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model Team {
  id        String        @id @default(uuid())
  name      String
  ownerId   String        @unique
  owner     User          @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  invites   TeamInvite[]
  domain    CustomDomain?
  brand     BrandSettings?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("member")
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model TeamInvite {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  phone     String
  token     String   @unique @default(uuid())
  expiresAt DateTime
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([teamId])
  @@index([token])
  @@index([phone])
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
}

model CustomDomain {
  id          String   @id @default(uuid())
  teamId      String   @unique
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  domain      String   @unique
  verified    Boolean  @default(false)
  verifyToken String   @unique @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
}

model BrandSettings {
  id           String   @id @default(uuid())
  teamId       String   @unique
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  logoUrl      String?
  primaryColor String?
  companyName  String?
  updatedAt    DateTime @updatedAt
}

model Analytics {
  id        String   @id @default(uuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  // Geo
  country   String?
  city      String?
  region    String?

  // Client
  device    String?
  browser   String?
  referrer  String?

  // Network (last octet masked for privacy, e.g. 1.2.3.x)
  ip        String?

  timestamp DateTime @default(now())

  @@index([linkId])
  @@index([linkId, timestamp])
}
